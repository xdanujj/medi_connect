# Port and Host configurations
PORT=8001
HOST=127.0.0.1

# LLM Providers Configuration
# You must provide at least one key for structured JSON generation.
# If both are provided, Gemini API takes precedence by default.
GEMINI_API_KEY=
OPENAI_API_KEY=

# LLM Model choices (e.g., gemini-1.5-flash, gemini-2.0-flash, gpt-4o-mini, gpt-4o)
# For Gemini, recommended is gemini-1.5-flash
# For OpenAI, recommended is gpt-4o-mini
MODEL_NAME=gemini-1.5-flash

# Whisper speech-to-text model name (tiny, base, small, medium, large-v3)
# 'small' is recommended for a balance of speed/accuracy on CPU.
# Use 'tiny' or 'base' for faster testing and lower memory.
WHISPER_MODEL_NAME=small

# Directory configurations (relative to ai_services or absolute paths)
UPLOAD_DIR=uploads
PDF_DIR=generated_pdfs
